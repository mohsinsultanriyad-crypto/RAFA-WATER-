{
  "name": "saudi-job",
  "private": true,
  "version": "0.0.0",
  
  "scripts": {
    "dev:server": "tsx server.ts",
    "dev:client": "vite",
    "dev": "concurrently -n server,client \"npm run dev:server\" \"npm run dev:client\"",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json && mv dist-server/server.js dist-server/server.cjs",
    "build": "npm run build:client && npm run build:server",
    "start:server": "node dist-server/server.cjs",
    "lint": "tsc --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.562.0",
    "mongoose": "^9.2.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
